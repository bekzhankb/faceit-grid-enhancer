{
    "manifest_version": 3,
    "name": "FACEIT Grid Enhancer",
    "version": "1.0.0",
    "description": "Advanced analytics, automation & QoL features for FACEIT",
    "permissions": [
        "storage",
        "alarms",
        "notifications"
    ],
    "host_permissions": [
        "https://*.faceit.com/*",
        "https://open.faceit.com/*",
        "http://localhost:8080/*"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": ["https://*.faceit.com/*"],
            "js": [
                "modules/dodgeList.js",
                "modules/dodgeCalc.js",
                "modules/mapVeto.js",
                "modules/qolFeatures.js",
                "content.js"
            ],
            "css": ["styles/enhancer.css"],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "web_accessible_resources": [
        {
            "resources": ["styles/*", "icons/*"],
            "matches": ["https://*.faceit.com/*"]
        }
    ]
}